DATABASE_URL=postgresql://udyoga:udyoga_pass@localhost:5432/udyogasakha_db

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate secrets with: openssl rand -hex 32
JWT_SECRET=replace_with_min_32_char_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_32_char_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (BullMQ job queue) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ── Sentry (Phase 1 — activate when DSN is available) ────────────────────────
# SENTRY_DSN=https://xxx@oNNN.ingest.sentry.io/xxx

# ── Swagger ────────────────────────────────────────────────────────────────────
# ⚠️ Set to false before real public launch — exposes interactive API docs publicly.
# Currently true so Swagger works during Railway staging/testing.
ENABLE_SWAGGER=true

# ── Frontend URL (used to build password reset links in emails) ──────────────
WEB_URL=http://localhost:3000

# ── Azure Communication Service (email delivery) ──────────────────────────────
# Get the connection string from: Azure Portal → your Communication Service
# resource → Settings → Keys. The sender address must be a verified domain
# (or the auto-generated "azurecomm.net" address) configured under
# Email → Domains in the same Communication Service resource.
# If left unset, emails are logged to console instead of sent — safe default
# for local development.
AZURE_COMMUNICATION_CONNECTION_STRING=
AZURE_EMAIL_SENDER_ADDRESS=DoNotReply@udyogasakha.in

# ── Razorpay (payments) ────────────────────────────────────────────────────────
# Get keys from: Razorpay Dashboard → Settings → API Keys.
# Use Test Mode keys (rzp_test_...) until ready to go live with rzp_live_...
#
# Standard Checkout automatically offers every payment method enabled on
# your account — no separate config needed per method:
#   • UPI (GPay, PhonePe, Paytm, BHIM, any UPI app — collect & intent flow)
#   • Debit & Credit Cards (Visa, Mastercard, RuPay, Amex, Diners)
#   • Net Banking (50+ Indian banks)
#   • Wallets (Paytm, Mobikwik, Freecharge, Amazon Pay, JioMoney, etc.)
#   • EMI (credit/debit card EMI, cardless EMI via Bajaj Finserv etc.)
#   • Pay Later (LazyPay, Simpl, ICICI PayLater, etc.)
#   • International Cards — requires a SEPARATE activation with Razorpay
#     support (additional KYC/business docs). Until activated, non-INR
#     order creation will be rejected by Razorpay's API even with valid keys.
#
# Webhook secret is set when you configure the webhook URL under
# Dashboard → Settings → Webhooks → add endpoint:
#   https://your-api-domain/api/v1/payments/webhook
# Subscribe to at minimum: payment.captured, payment.failed, refund.processed
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── File Storage ────────────────────────────────────────────────────────────────
# 'local' = files on disk (default, fine for dev — but ephemeral on Railway,
#           wiped on every redeploy). 'azure' = Azure Blob Storage (persistent).
# No code change needed to switch — flip STORAGE_PROVIDER and redeploy.
STORAGE_PROVIDER=local

# Only needed when STORAGE_PROVIDER=azure.
# Get the connection string from: Azure Portal → your Storage Account →
# Security + networking → Access keys → key1 → Connection string.
# The container is created automatically on first use (private — no public
# read access; files are served via short-lived SAS download links).
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER_NAME=udyogasakha-documents
