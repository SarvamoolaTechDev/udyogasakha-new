DATABASE_URL=postgresql://udyoga:udyoga_pass@localhost:5432/udyogasakha_db

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate secrets with: openssl rand -hex 32
JWT_SECRET=replace_with_min_32_char_secret_here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_different_32_char_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (BullMQ job queue) ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# ── Sentry (Phase 1 — activate when DSN is available) ────────────────────────
# SENTRY_DSN=https://xxx@oNNN.ingest.sentry.io/xxx

# ── Swagger ────────────────────────────────────────────────────────────────────
# ⚠️ Set to false before real public launch — exposes interactive API docs publicly.
# Currently true so Swagger works during Railway staging/testing.
ENABLE_SWAGGER=true

# ── Frontend URL (used to build password reset links in emails) ──────────────
WEB_URL=http://localhost:3000
