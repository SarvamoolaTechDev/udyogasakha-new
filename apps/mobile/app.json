{
  "expo": {
    "name": "Udyoga Sakha",
    "slug": "udyogasakha",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#030917",
    "splash": {
      "backgroundColor": "#030917",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "in.udyogasakha.app"
    },
    "android": {
      "adaptiveIcon": { "backgroundColor": "#030917" },
      "package": "in.udyogasakha.app"
    },
    "plugins": ["expo-secure-store", "expo-font"]
  }
}
