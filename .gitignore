# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Environment variables ───────────────────────────────────────────────────
# .env.example files ARE committed — only real secrets are excluded.
.env
.env.local
.env.*.local
.env.development.local
.env.production.local

# ── Next.js (apps/web, apps/admin) ──────────────────────────────────────────
.next/
out/
next-env.d.ts

# ── NestJS (apps/api) ────────────────────────────────────────────────────────
dist/

# ── Turborepo ────────────────────────────────────────────────────────────────
.turbo/

# ── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo

# ── Testing ──────────────────────────────────────────────────────────────────
coverage/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Uploaded files (local filesystem storage adapter — ephemeral test data) ──
uploads/

# ── Expo / React Native (apps/mobile) ────────────────────────────────────────
.expo/
.expo-shared/
dist/
web-build/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
credentials.json

# ── Prisma ───────────────────────────────────────────────────────────────────
# IMPORTANT: prisma/migrations/ is intentionally NOT listed here.
# Migration history must be committed — `prisma migrate deploy` on Railway
# replays exactly the migration files tracked in git. Ignoring this folder
# means deployments have nothing to apply.

# ── Editor / OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/*
!.vscode/extensions.json

# ── Sentry (if CLI auth token ever configured locally) ───────────────────────
.sentryclirc